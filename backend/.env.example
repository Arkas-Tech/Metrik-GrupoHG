# ── Google Ads API ──────────────────────────────────────────────────────────────
# Nunca compartas estas credenciales ni las incluyas en el repositorio.
# developer_token: Herramientas → Centro de la API de Google Ads (tu cuenta de Ads)
# client_id + client_secret: Google Cloud Console → Credenciales → OAuth 2.0
# customer_id: ID de cliente de 10 dígitos en Google Ads (sin guiones)
# El refresh_token se obtiene via la UI de administrador en /campanas (botón Conectar Google Ads)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_CUSTOMER_ID=
