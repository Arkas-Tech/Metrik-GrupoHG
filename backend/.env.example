DB_TYPE=postgresql
DB_USER=postgres
DB_PASSWORD=tu_password_seguro
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgpme

JWT_SECRET_KEY=tu_secret_key_muy_seguro_aqui_cambialo_en_produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=43200

# ── Google Ads API ──────────────────────────────────────────────────────────────
# Nunca compartas estas credenciales ni las incluyas en el repositorio.
# developer_token: Herramientas → Centro de la API de Google Ads (tu cuenta de Ads)
# client_id + client_secret: Google Cloud Console → Credenciales → OAuth 2.0
# MANAGER_ID: ID de la cuenta administradora / MCC (si gestionas varias marcas desde una sola cuenta)
#   - Conéctate a ads.google.com y mira el número de 10 dígitos arriba a la derecha (sin guiones)
#   - Si usas MCC, este ID va como 'login-customer-id' en todas las llamadas a la API
# CUSTOMER_ID: ID de cliente fallback si solo tienes UNA cuenta (sin MCC)
#   - Si tienes varias marcas, deja este vacío y configura el mapa desde la UI de Metrik
# El mapa marca → customer_id se configura desde la app (/campanas → Conectar Google Ads)
# El refresh_token también se obtiene desde la UI de administrador en /campanas
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_MANAGER_ID=       # ID de cuenta MCC/administradora (recomendado si hay varias marcas)
GOOGLE_ADS_CUSTOMER_ID=      # ID fallback si solo hay una cuenta (dejar vacío si usas MCC + customer_map)
